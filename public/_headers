# Issue #730 — Cache headers for Cloudflare Pages
# Vite-built assets have content hashes in their filenames, so they are
# safe to cache forever. Everything else in /public/ (images, audio, icons)
# uses fixed filenames and must revalidate on every request so PWA installs
# pick up updates without waiting for browser cache expiry.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/avatars/*
  Cache-Control: no-cache

/mascots/*
  Cache-Control: no-cache

/icons/*
  Cache-Control: no-cache

/splash/*
  Cache-Control: no-cache

/tickets/*
  Cache-Control: no-cache

/coins/*
  Cache-Control: no-cache

/sfx/*
  Cache-Control: no-cache

/mascote*.png
  Cache-Control: no-cache

/login-*.png
  Cache-Control: no-cache

/hero-bg-*.png
  Cache-Control: no-cache

/logomarca*.png
  Cache-Control: no-cache

/loginpage-brand.png
  Cache-Control: no-cache

/events-background.png
  Cache-Control: no-cache

/hearthbound-plate.png
  Cache-Control: no-cache

/sanctuary-header-bg.png
  Cache-Control: no-cache

/vocabulary-garden-cat.png
  Cache-Control: no-cache

/rarity-*.png
  Cache-Control: no-cache

/reward-icon.png
  Cache-Control: no-cache

/achievements-icon.png
  Cache-Control: no-cache

/progress-bar-pin.png
  Cache-Control: no-cache
